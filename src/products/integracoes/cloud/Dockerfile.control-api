FROM node:22-slim AS builder

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml ./
COPY tsconfig.json next-env.d.ts ./
COPY src ./src

RUN pnpm install --frozen-lockfile --ignore-scripts
RUN pnpm --dir src/products/integracoes/cloud build:control-api

FROM node:22-slim AS runner

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=8080

COPY --from=builder /app/src/products/integracoes/cloud/dist/control-api ./dist/control-api

EXPOSE 8080

CMD ["node", "dist/control-api/index.js"]
