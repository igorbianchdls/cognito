{
  "name": "@cognito/integracoes-cloud",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:control-api": "pnpm --dir ../../../.. exec esbuild src/products/integracoes/cloud/src/control-api/index.ts --bundle --platform=node --format=esm --target=node22 --outfile=src/products/integracoes/cloud/dist/control-api/index.js",
    "build:worker": "pnpm --dir ../../../.. exec esbuild src/products/integracoes/cloud/src/worker/index.ts --bundle --platform=node --format=esm --target=node22 --outfile=src/products/integracoes/cloud/dist/worker/index.js",
    "build": "pnpm build:control-api && pnpm build:worker",
    "check": "tsc --noEmit",
    "start:control-api": "node dist/control-api/index.js",
    "start:worker": "node dist/worker/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {}
}
