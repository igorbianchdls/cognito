# API Keys necessárias para o funcionamento do sistema

# Anthropic Claude API (necessário para chat)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# BigQuery Configuration (necessário para conectar aos seus dados)
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/bigquery-key.json
BIGQUERY_DATASET_ID=your-dataset-id
BIGQUERY_LOCATION=US

# Para produção (Vercel), use esta variável em vez do arquivo acima:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Alternativa dedicada ao BigQuery; aceita JSON puro ou base64 do JSON.
# BIGQUERY_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Next.js Configuration
NEXTJS_URL=http://localhost:3000

# Integracoes GCP Control API
# Usado por /integracoes para despachar setup/sync ao Cloud Run.
INTEGRATIONS_CONTROL_API_URL=https://integrations-control-api-305346154546.southamerica-east1.run.app
INTEGRATIONS_INTERNAL_API_KEY=your-integrations-internal-api-key
INTEGRATIONS_OAUTH_REDIRECT_URI=https://integrations-control-api-305346154546.southamerica-east1.run.app/callbacks/provider
INTEGRATIONS_APP_CALLBACK_URL=https://cognito-305346154546.southamerica-east1.run.app/integracoes/callback
# Opcional: token server-to-server para APIs Next.js de /integracoes.
INTEGRACOES_API_TOKEN=your-integracoes-api-token
# Opcional: tenant usado quando INTEGRACOES_API_TOKEN autentica sem tenant explicito.
INTEGRACOES_API_TENANT_ID=1
# Apenas desenvolvimento local: permite acessar /integracoes sem sessao Supabase.
INTEGRACOES_DEV_TENANT_ID=1

# Supabase Configuration (necessário para autenticação e banco de dados)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Direct Database Connection (necessário para conexão direta PostgreSQL)
# Como obter: Supabase Dashboard > Project Settings > Database > Connection String > URI
# Use o modo "Session" (não "Transaction") para compatibilidade total
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=your-supabase-connection-string-uri

# Vercel Sandbox Snapshot (acelera inicialização do chat)
# Segredo para criar snapshots via API admin
ADMIN_SNAPSHOT_SECRET=your-admin-snapshot-secret
# Último snapshotId gerado (renovar a cada 7 dias)
SANDBOX_SNAPSHOT_ID=your-latest-snapshot-id
# Opcional: versão lógica para forçar rotação quando mudar dependências/seed
SNAPSHOT_VERSION=1

# Instruções:
# 1. Copie este arquivo para .env.local
# 2. Substitua os valores pelas suas configurações reais
# 3. Para BigQuery, siga o guia em BIGQUERY_SETUP.md
# 4. Para Anthropic: https://console.anthropic.com/
# 5. Para Supabase: https://supabase.com/dashboard (Settings > API)
# 6. Para Snapshot: gere via POST /api/sandbox/snapshot com header x-admin-secret
# AssemblyAI (Speech-to-Text)
# Crie uma API key em https://www.assemblyai.com/ e cole aqui
ASSEMBLYAI_API_KEY=

# ElevenLabs (Speech-to-Text)
# Crie uma API key em https://elevenlabs.io/ e cole aqui
ELEVENLABS_API_KEY=

# AgentMail (email API)
# https://www.agentmail.dev/ — coloque sua chave aqui
AGENTMAIL_API_KEY=

# OpenAI Codex SDK (POC em /bigquery-test/codex-some)
CODEX_API_KEY=your-codex-api-key
# Opcional: endpoint compatível com API OpenAI
# OPENAI_BASE_URL=
